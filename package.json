{
  "name": "ai-employee",
  "private": true,
  "version": "0.1.0",
  "description": "AI Employee online and desktop assistant. Permissioned, audited, with local encrypted memory and connector boundaries for email/WhatsApp.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/desktop",
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -b --pretty",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0",
    "electron-rebuild": "^3.2.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
